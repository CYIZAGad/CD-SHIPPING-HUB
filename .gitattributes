# Shell scripts should use LF line endings
*.sh text eol=lf
docker-entrypoint.sh text eol=lf

# Other files
*.php text eol=lf
*.json text eol=lf
*.md text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.env.example text eol=lf
.gitignore text eol=lf
.htaccess text eol=lf

# Binary files
*.jpg binary
*.png binary
*.gif binary
*.avif binary
